{
	"name": "convertigo-studio-web",
	"version": "8.4.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node post-build.js",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-check --tsconfig ./jsconfig.json --ignore \"src/lib/studio/**/*\" --watch",
		"test": "npm run test:integration && npm run test:unit",
		"lint": "prettier --plugin prettier-plugin-svelte --check . && eslint .",
		"format": "prettier --write .",
		"test:integration": "playwright test",
		"test:unit": "vitest",
		"check:palette": "node scripts/check-skeleton-pairs.mjs",
		"update:bezels": "node scripts/update-bezels.mjs",
		"generate:thumbnails": "node scripts/generate-thumbnails.mjs",
		"deps:update": "npx npm-check-updates && npx npm-check-updates --no-peer --reject '/^(?!(svelte|tailwindcss)$).*/' && npm install",
		"deps:minor-update": "npx npm-check-updates --target minor && npx npm-check-updates --target minor --no-peer --reject '/^(?!(svelte|tailwindcss)$).*/' && npm install",
		"check:admin": "svelte-check --no-tsconfig --ignore \"src/lib/studio/**,src/routes/(app)/admin/certificates/**,src/routes/(app)/admin/projects/**,src/routes/(app)/admin/roles/**,src/routes/(app)/admin/symbols/**\"",
		"lint:admin": "eslint \"src/lib/admin/**/*.{js,svelte,ts}\" \"src/lib/common/**/*.{js,svelte,ts}\" \"src/lib/dashboard/**/*.{js,svelte,ts}\" \"src/lib/utils/**/*.{js,svelte,ts}\" \"src/routes/(app)/admin/**/*.{js,svelte,ts}\" \"src/routes/(app)/dashboard/**/*.{js,svelte,ts}\" \"src/routes/(root)/login/**/*.{js,svelte,ts}\" \"src/routes/+layout.svelte\" \"src/routes/(app)/+layout.svelte\" --ignore-pattern \"src/routes/(app)/admin/certificates/**\" --ignore-pattern \"src/routes/(app)/admin/projects/**\" --ignore-pattern \"src/routes/(app)/admin/roles/**\" --ignore-pattern \"src/routes/(app)/admin/symbols/**\""
	},
	"overrides": {
		"svelte-tiny-virtual-list": {
			"@types/svelte": "^5.0.0",
			"svelte": "^5.55.1"
		}
	},
	"devDependencies": {
		"@eslint/js": "^9.39.2",
		"@fontsource-variable/ibm-plex-sans": "^5.2.8",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@iconify-json/mdi": "^1.2.3",
		"@iconify/svelte": "^5.2.1",
		"@playwright/test": "^1.58.2",
		"@skeletonlabs/skeleton": "^4.13.0",
		"@skeletonlabs/skeleton-svelte": "^4.13.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/typography": "0.5.19",
		"@types/node": "^25.5.0",
		"@typescript-eslint/parser": "^8.58.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"postcss-nesting": "^14.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"sharp": "^0.34.5",
		"svelte": "^5.55.1",
		"svelte-check": "^4.4.6",
		"svelte-eslint-parser": "^1.6.0",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.3.1",
		"vitest": "^4.1.2"
	},
	"type": "module",
	"dependencies": {
		"@flaticon/flaticon-uicons": "^3.3.1",
		"@floating-ui/dom": "^1.7.6",
		"@internationalized/date": "^3.12.0",
		"@tailwindcss/vite": "^4.2.2",
		"@xyflow/svelte": "^1.5.2",
		"@zag-js/tree-view": "^1.38.2",
		"apexcharts": "^5.10.4",
		"bits-ui": "^2.16.5",
		"caniuse-lite": "^1.0.30001782",
		"chart.js": "^4.5.1",
		"elkjs": "^0.11.1",
		"fast-xml-parser": "^5.5.9",
		"fs-extra": "^11.3.4",
		"html-entities": "^2.6.0",
		"marked": "^17.0.5",
		"monaco-editor": "^0.55.1",
		"svelte-persisted-state": "^1.4.0",
		"svelte-persisted-store": "^0.12.0",
		"svelte-tiny-virtual-list": "^3.0.1"
	}
}
